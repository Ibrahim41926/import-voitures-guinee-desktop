<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.importation.ui.VoitureUIController"
      styleClass="page">

    <HBox spacing="18" alignment="CENTER_LEFT" styleClass="page-toolbar">
        <VBox spacing="4">
            <Label text="Catalogue" styleClass="eyebrow"/>
            <Label text="Gestion des Voitures" styleClass="title"/>
            <Label text="Recherche, suivi et edition du parc automobile." styleClass="lead-secondary" wrapText="true"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="toolbar-actions">
            <Button text="+ Ajouter Voiture" onAction="#afficherFormulaire" styleClass="button-accent"/>
            <Button text="Modifier" onAction="#modifierVoiture" styleClass="button-secondary"/>
            <Button text="Supprimer" onAction="#supprimerVoiture" styleClass="button-secondary"/>
        </HBox>
    </HBox>

    <HBox spacing="14" alignment="CENTER_LEFT" styleClass="search-panel">
        <VBox spacing="4">
            <Label text="Recherche rapide" styleClass="section-title"/>
            <Label text="Filtre par marque, modele ou immatriculation." styleClass="section-note"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Marque, modele ou immatriculation..." prefWidth="320"/>
        <Button text="Rechercher" onAction="#rechercher"/>
        <Button text="Reinitialiser" onAction="#afficherTous" styleClass="button-secondary"/>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" styleClass="table-card-header">
            <VBox spacing="4">
                <Label text="Inventaire vehicules" styleClass="section-title"/>
                <Label text="Vue de travail pour parcourir, modifier et supprimer les enregistrements." styleClass="section-note"/>
            </VBox>
        </HBox>
        <TableView fx:id="tableVoitures" prefHeight="300" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="ID" prefWidth="40" sortable="false">
                    <cellValueFactory><PropertyValueFactory property="id" /></cellValueFactory>
                </TableColumn>
                <TableColumn text="Marque" prefWidth="80" sortable="false">
                    <cellValueFactory><PropertyValueFactory property="marque" /></cellValueFactory>
                </TableColumn>
                <TableColumn text="Modele" prefWidth="80" sortable="false">
                    <cellValueFactory><PropertyValueFactory property="modele" /></cellValueFactory>
                </TableColumn>
                <TableColumn text="Annee" prefWidth="60" sortable="false">
                    <cellValueFactory><PropertyValueFactory property="annee" /></cellValueFactory>
                </TableColumn>
                <TableColumn text="Immatriculation" prefWidth="100" sortable="false">
                    <cellValueFactory><PropertyValueFactory property="immatriculation" /></cellValueFactory>
                </TableColumn>
                <TableColumn text="Prix Achat CAD" prefWidth="100" sortable="false">
                    <cellValueFactory><PropertyValueFactory property="prixAchatCAD" /></cellValueFactory>
                </TableColumn>
                <TableColumn text="Statut" prefWidth="80" sortable="false">
                    <cellValueFactory><PropertyValueFactory property="statut" /></cellValueFactory>
                </TableColumn>
                <TableColumn text="Date Import" prefWidth="100" sortable="false">
                    <cellValueFactory><PropertyValueFactory property="dateImportation" /></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>
    </VBox>

</VBox>
