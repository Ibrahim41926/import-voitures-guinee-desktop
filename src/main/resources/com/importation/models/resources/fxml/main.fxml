<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.importation.ui.MainController"
            prefHeight="800" prefWidth="1200"
            styleClass="app-shell">
    <top>
        <VBox styleClass="top-bar" spacing="18">
            <HBox alignment="CENTER_LEFT" spacing="18" styleClass="masthead">
                <VBox spacing="4">
                    <Label text="Importation Canada -> Guinee" styleClass="eyebrow"/>
                    <Label text="Centre de pilotage" styleClass="brand-title"/>
                    <Label text="Suivi des voitures, associes, taux de change et operations internes." styleClass="brand-subtitle" wrapText="true"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox alignment="CENTER_RIGHT" spacing="4" styleClass="masthead-chip">
                    <Label text="Poste actuel" styleClass="chip-label"/>
                    <Label text="Desktop control room" styleClass="chip-value"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="nav-strip">
                <Button fx:id="navDashboardButton" text="Tableau de Bord" onAction="#afficherTableauBord" styleClass="nav-button"/>
                <Button fx:id="navVoituresButton" text="Voitures" onAction="#afficherVoitures" styleClass="nav-button"/>
                <Button fx:id="navAssociesButton" text="Associes" onAction="#afficherAssocies" styleClass="nav-button"/>
                <Button fx:id="navTauxButton" text="Taux de change" onAction="#afficherTauxChange" styleClass="nav-button"/>
                <Button fx:id="navBaseButton" text="Base de donnees" onAction="#afficherBaseDonnees" styleClass="nav-button"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="mainContent" styleClass="content-shell">
            <VBox fx:id="tableauBordPane" styleClass="page">
                <VBox styleClass="page-header" spacing="6">
                    <Label text="Vue globale" styleClass="eyebrow"/>
                    <Label text="Tableau de Bord" styleClass="title"/>
                    <Label text="Synthese des indicateurs clés, inventaire rapide et actions courantes." styleClass="lead-secondary" wrapText="true"/>  
                </VBox>

                <HBox spacing="14" styleClass="kpi-row">
                    <VBox styleClass="kpi-card-teal" prefWidth="190">
                        <Label text="Inventaire" styleClass="kpi-tag"/>
                        <Label text="Total voitures" styleClass="subtitle"/>
                        <Label fx:id="kpiTotalVoitures" text="0" styleClass="kpi-value"/>
                    </VBox>
                    <VBox styleClass="kpi-card-amber" prefWidth="190">
                        <Label text="Vente" styleClass="kpi-tag"/>
                        <Label text="Voitures vendues" styleClass="subtitle"/>
                        <Label fx:id="kpiVoituresVendues" text="0" styleClass="kpi-value"/>
                    </VBox>
                    <VBox styleClass="kpi-card-copper" prefWidth="190">
                        <Label text="Reseau" styleClass="kpi-tag"/>
                        <Label text="Total associés" styleClass="subtitle"/>
                        <Label fx:id="kpiTotalAssocies" text="0" styleClass="kpi-value"/>
                    </VBox>
                    <VBox styleClass="kpi-card-ink" prefWidth="250">
                        <Label text="Finance" styleClass="kpi-tag"/>
                        <Label text="Contributions (GNF)" styleClass="subtitle"/>
                        <Label fx:id="kpiTotalContributions" text="0 GNF" styleClass="kpi-value"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-bar">
                    <Button text="Modifier voiture selectionnée" onAction="#modifierVoitureDashboard" styleClass="button-secondary"/>
                    <Button text="Supprimer voiture selectionnée" onAction="#supprimerVoitureDashboard" styleClass="button-secondary"/>
                    <Button text="Exporter en PDF" onAction="#exporterTableauBordPdf" styleClass="button-secondary"/>
                </HBox>

                <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" styleClass="table-card-header">
                        <VBox spacing="4">
                            <Label text="Inventaire detaillé" styleClass="section-title"/>
                            <Label text="Selectionne une ligne pour modifier, supprimer ou exporter." styleClass="section-note"/>
                        </VBox>
                    </HBox>
                    <TableView fx:id="dashboardTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="45"/>
                            <TableColumn fx:id="colMarque" text="Marque" prefWidth="100"/>
                            <TableColumn fx:id="colModele" text="Modele" prefWidth="100"/>
                            <TableColumn fx:id="colAnnee" text="Année" prefWidth="70"/>
                            <TableColumn fx:id="colImmatriculation" text="Immatriculation" prefWidth="120"/>
                            <TableColumn fx:id="colPrixAchatCad" text="Prix achat CAD" prefWidth="120"/>
                            <TableColumn fx:id="colTransportCad" text="Transport CAD" prefWidth="110"/>
                            <TableColumn fx:id="colAssuranceCad" text="Assurance CAD" prefWidth="110"/>
                            <TableColumn fx:id="colDedouanementGnf" text="Dedouanement GNF" prefWidth="130"/>
                            <TableColumn fx:id="colFraisDiversCad" text="Frais divers CAD" prefWidth="120"/>
                            <TableColumn fx:id="colFraisDiversGnf" text="Frais divers GNF" prefWidth="120"/>
                            <TableColumn fx:id="colCoutTotalGnf" text="Cout total (GNF)" prefWidth="140"/>
                            <TableColumn fx:id="colPrixReventeGnf" text="Prix Revente GNF" prefWidth="120"/>
                            <TableColumn fx:id="colDateImportation" text="Date Importation" prefWidth="120"/>
                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="90"/>
                            <TableColumn fx:id="colAssocie" text="Associe" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>

            <VBox fx:id="voituresPane" styleClass="page-host"/>
            <VBox fx:id="associesPane" styleClass="page-host"/>

            <VBox fx:id="tauxChangePane" styleClass="page">
                <VBox styleClass="page-header" spacing="6">
                    <Label text="Finance" styleClass="eyebrow"/>
                    <Label text="Gestion Taux de Change" styleClass="title"/>
                    <Label text="Ajuste le referentiel CAD -> GNF avant de recalculer les operations." styleClass="lead" wrapText="true"/>
                </VBox>

                <HBox spacing="16">
                    <VBox styleClass="feature-card" spacing="12" maxWidth="560">
                        <Label fx:id="tauxActuelLabel" text="1 CAD = 0 GNF" styleClass="kpi-value"/>
                        <Label text="Saisissez un nouveau taux (GNF pour 1 CAD)." styleClass="lead-secondary" wrapText="true"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="nouveauTauxField" promptText="Ex: 6400"/>
                            <Button text="Appliquer" onAction="#appliquerNouveauTaux"/>
                            <Button text="Par defaut" onAction="#reinitialiserTauxDefaut" styleClass="button-secondary"/>
                        </HBox>
                        <Label text="Le taux est persisté et réutilisé sur les écrans de coûts, ventes et exports." styleClass="section-note" wrapText="true"/>
                    </VBox>

                    <VBox styleClass="info-card" spacing="10" prefWidth="280">
                        <Label text="Impact direct" styleClass="section-title"/>
                        <Label text="Chaque variation du taux influence les coûts convertis, le tableau de bord et la lecture des marges." styleClass="body-copy" wrapText="true"/>
                        <Label text="Utilise un taux stable avant d exporter ou d imprimer les donnees." styleClass="section-note" wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="baseDonneesPane" styleClass="page">
                <VBox styleClass="page-header" spacing="6">
                    <Label text="Zone avancée" styleClass="eyebrow"/>
                    <Label text="Gestion Base de Données" styleClass="title"/>
                    <Label text="Execute des requetes SQLite pour auditer ou corriger les donnees." styleClass="lead" wrapText="true"/>
                </VBox>

                <VBox styleClass="sql-card" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" styleClass="table-card-header">
                        <VBox spacing="4">
                            <Label text="Console SQL" styleClass="section-title"/>
                            <Label text="Lecture et ecriture directes sur la base locale." styleClass="section-note"/>
                        </VBox>
                    </HBox>
                    <Label text="Requete SQL" styleClass="subtitle"/>
                    <TextArea fx:id="sqlQueryArea" prefRowCount="6" promptText="Ex: SELECT * FROM VOITURE;" styleClass="sql-editor"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Executer" onAction="#executerSql"/>
                        <Button text="Effacer" onAction="#effacerSql" styleClass="button-secondary"/>
                    </HBox>
                    <Label text="Resultat" styleClass="subtitle"/>
                    <TextArea fx:id="sqlResultArea" prefRowCount="14" editable="false" VBox.vgrow="ALWAYS" styleClass="sql-output"/>
                </VBox>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <HBox styleClass="status-bar" spacing="12" alignment="CENTER_LEFT">
            <Label text="Etat session" styleClass="status-caption"/>
            <Separator orientation="VERTICAL"/>
            <Label fx:id="statusLabel" text="Pret" styleClass="status-value"/>
        </HBox>
    </bottom>
</BorderPane>
